{
	"name": "@marianmeres/stuic",
	"version": "3.112.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pnpm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"package": "pnpm run prepack",
		"package:watch": "svelte-kit sync && svelte-package --watch && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "eslint . && prettier --check .",
		"test": "vitest --dir src/",
		"svelte-check": "svelte-check",
		"svelte-package": "svelte-package",
		"rp": "pnpm run build && ./release.sh patch",
		"rpm": "pnpm run build && ./release.sh minor"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"docs",
		"AGENTS.md",
		"CLAUDE.md",
		"API.md"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./utils": {
			"types": "./dist/utils/index.d.ts",
			"default": "./dist/utils/index.js"
		},
		"./phone-validation": {
			"types": "./dist/components/Input/phone-validation.d.ts",
			"default": "./dist/components/Input/phone-validation.js"
		},
		"./markdown-editor": {
			"types": "./dist/components/MarkdownEditor/index.d.ts",
			"svelte": "./dist/components/MarkdownEditor/index.js",
			"default": "./dist/components/MarkdownEditor/index.js"
		}
	},
	"peerDependencies": {
